{
	"name": "obsidian-blog-push",
	"version": "1.0.4",
	"description": "Push Obsidian notes to a GitHub-backed Astro blog.",
	"main": "main.js",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "rolldown -c --watch",
		"build": "tsc --noEmit --skipLibCheck && rolldown -c --environment BUILD:production",
		"typecheck": "tsc --noEmit --skipLibCheck",
		"version": "node version-bump.mjs && git add package.json manifest.json versions.json",
		"lint": "oxlint"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@types/node": "^24.1.0",
		"oxlint": "^1.62.0",
		"rolldown": "1.0.0-rc.18",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@octokit/request-error": "^7.1.0",
		"@octokit/rest": "^22.0.1",
		"obsidian": "1.12.3"
	}
}
